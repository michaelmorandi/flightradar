# Flight Radar — environment configuration.
# Copy to .env and fill in your values.

# =============================================================================
# FRONTEND
# =============================================================================

# API URL the frontend talks to. Local dev: the Rust backend on 8083.
VITE_FLIGHT_API_URL=http://localhost:8083/api/v1

VITE_HERE_API_KEY=your-here-api-key

# Mock data mode for development (true/false)
VITE_MOCK_DATA=false

# Enable position interpolation on the client (true/false)
VITE_ENABLE_INTERPOLATION=true

# Optional Umami analytics ID
VITE_UMAMI_ID=

# =============================================================================
# BACKEND — required
# =============================================================================

# MongoDB connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB=flightradar

# Realtime ADS-B source. Choose one:
#   dump1090 — HTTP polling of {RADAR_ENDPOINT}/data/aircraft.json
#   grpc     — tonic streaming subscription to {RADAR_ENDPOINT}
RADAR_KIND=dump1090
RADAR_ENDPOINT=http://localhost:8080

# JWT signing secret. MUST be ≥ 32 bytes.
# Generate: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-real-32-byte-secret

# =============================================================================
# BACKEND — optional
# =============================================================================

# HTTP listen address
BIND_ADDR=0.0.0.0:8083

# Comma-separated CORS origins (defaults to http://localhost:5173)
ALLOWED_ORIGINS=

# Encrypted-cookie key: 64-byte hex. Omit to generate an ephemeral key
# on each boot (sessions don't survive restarts in that mode).
# Generate: openssl rand -hex 64
COOKIE_KEY=

# Session token lifetime in seconds (default: 900 = 15 min)
TOKEN_LIFETIME_SECS=900

# Realtime tuning
FLUSH_INTERVAL_SECS=2
POSITION_TTL_SECS=60
MILITARY_ONLY=false

# Aircraft metadata enrichment via nighthawk-proxy.
# Omit to disable metadata lookups entirely.
NIGHTHAWK_BASE_URL=http://nighthawk-proxy:8000

# Static airline directory file (operators.json shape). The container
# already sets AIRLINES_FILE=/home/radar/resources/operators.json in the
# Dockerfile, so only override when running outside the container.
# AIRLINES_FILE=

# Aircraft metadata crawler — periodic background enrichment.
CRAWLER_ENABLED=false
CRAWLER_INTERVAL_SECS=20

# Admin account seeding. Both must be set; the admin is upserted on boot
# only if not already present.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# =============================================================================
# OBSERVABILITY (OTEL)
# =============================================================================

# OTLP gRPC endpoint for tracing export. Omit to disable OTEL export
# (structured JSON logs continue to stdout regardless).
# Example: http://otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# Standard env-driven `tracing` level / target filter.
# Default in production: info,hyper=warn,tonic=warn,mongodb=info
# RUST_LOG=info

# =============================================================================
# NOTES
# =============================================================================
#
# 1. Generate secure secrets with `openssl rand -hex 32` (or 64 for COOKIE_KEY).
# 2. JWT_SECRET and COOKIE_KEY must be different from each other.
# 3. Never commit .env to version control.
# 4. Rotate secrets periodically in production.
# 5. Auth uses HTTP-only encrypted cookies (15 min lifetime by default,
#    sliding refresh on each request).
